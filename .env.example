# Monero Gateway Configuration
MONERO_NETWORK=stagenet
GATEWAY_API_KEY=ripley_secure_key_123
MAX_XMR_PER_REQUEST=0.1
MAX_XMR_PER_DAY=0.5
DATA_DIR=./data/gateway

# Wallet Configuration
WALLET_RPC_URL=http://wallet-rpc:38083/json_rpc
MONERO_BOOTSTRAP_ADDRESS=rpc-stagenet.kyc.rip:443
MONERO_DAEMON_ADDRESS=rpc-stagenet.kyc.rip:443
MONERO_DAEMON_SSL=enabled

# Local Full Node Option (Uncomment to use with 'full-node' profile)
# MONERO_DAEMON_ADDRESS=monero-node:38089
# MONERO_DAEMON_SSL=disabled

# Required for the Ripley Agent Gateway
AGENT_API_KEY=ripley_secure_key_123

# Required for Global Access via Cloudflare Tunnel
CLOUDFLARE_TUNNEL_TOKEN=your_token_here

# Required for the Ripley Agent POC (example script)
# GEMINI_API_KEY=your_key_here
